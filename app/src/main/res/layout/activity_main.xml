<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:padding="16dp">

    <!-- 标题 -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🤖 AI 手机助手"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#1E293B"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- 服务状态 -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⏹ 未启动"
        android:textSize="14sp"
        android:textColor="#EF4444"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- 悬浮窗状态 -->
    <TextView
        android:id="@+id/tvFloatStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⏹ 悬浮窗未启动"
        android:textSize="12sp"
        android:textColor="#94A3B8"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvStatus"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- 按钮行 -->
    <LinearLayout
        android:id="@+id/btnRow1"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvFloatStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 开启无障碍权限 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOpenSettings"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="🔓 无障碍权限"
            android:textAllCaps="false"
            android:textSize="13sp"
            app:cornerRadius="12dp"
            app:backgroundTint="#6366F1"
            android:layout_marginEnd="8dp" />

        <!-- 启动悬浮窗 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFloat"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="🫧 启动悬浮窗"
            android:textAllCaps="false"
            android:textSize="13sp"
            app:cornerRadius="12dp"
            app:backgroundTint="#8B5CF6" />
    </LinearLayout>

    <!-- API Key 输入 -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilApiKey"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="AI API Key"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/btnRow1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etApiKey"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textPassword"
            android:textSize="14sp" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- API URL 输入 -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilApiUrl"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="API 地址"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tilApiKey"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etApiUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="https://api.openai.com/v1/chat/completions"
            android:textSize="14sp" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- 指令输入 -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilCommand"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="输入指令，如：打开微信 / 回到桌面"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/tilApiUrl"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etCommand"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:maxLines="3" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- 执行按钮 + 语音按钮 -->
    <LinearLayout
        android:id="@+id/btnRow2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/tilCommand"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 执行 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnExecute"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="🚀 执行"
            android:textAllCaps="false"
            android:textSize="13sp"
            app:cornerRadius="12dp"
            app:backgroundTint="#10B981"
            android:layout_marginEnd="8dp" />

        <!-- 语音输入 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnVoice"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="🎤 语音输入"
            android:textAllCaps="false"
            android:textSize="13sp"
            app:cornerRadius="12dp"
            app:backgroundTint="#F59E0B" />
    </LinearLayout>

    <!-- 语音识别状态 -->
    <TextView
        android:id="@+id/tvVoiceStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="13sp"
        android:textColor="#6366F1"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/btnRow2"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- 日志区域 -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#FFFFFF"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvVoiceStatus"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:textSize="13sp"
            android:textColor="#475569"
            android:fontFamily="monospace"
            android:text="等待操作...\n" />
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
